# ─────────────────────────────────────────────────────────────
# ผ่อนกับอิ้ง / Ticketify — environment variables
# Copy this file to ".env.local" and fill in the real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── LINE Login channel (website auth) — from Step 3 ──
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# Where LINE sends users back after login.
# Must EXACTLY match a Callback URL set in the LINE Login channel.
LINE_LOGIN_CALLBACK_URL=http://localhost:3000/api/auth/line/callback

# Scopes requested at login. Add "email" only after email permission is approved (Step 6).
LINE_LOGIN_SCOPE=profile openid

# ── Official Account basic ID (for the "add friend" gate), e.g. @xxxxxxx ──
LINE_OA_BASIC_ID=

# ── Messaging API channel / Official Account — from Step 4 ──
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
LINE_MESSAGING_CHANNEL_SECRET=

# ── App ──
# A random string used to sign your own session/cookies (generate one, e.g. `openssl rand -hex 32`).
SESSION_SECRET=
# Base URL of the app (used to build the callback + redirects).
APP_BASE_URL=http://localhost:3000

# ── Supabase Storage (concert poster uploads) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Database (Supabase Postgres) ──
# DATABASE_URL = pooled connection (port 6543) + ?pgbouncer=true
# DIRECT_URL   = direct connection (port 5432), used by migrations
DATABASE_URL=
DIRECT_URL=

# ── Payments (Phase 4.3) — no gateway, no pay page, manual transfer + slips ──
# No payment gateway or web pay page anymore (Omise/Beam/QR all removed).
# Customers transfer to one of your accounts and send a slip photo in LINE chat;
# EasySlip verifies it and we auto-confirm the payment when the amount matches.

# Your receiving accounts, shown as text rows inside the LINE invoice/reminder
# messages. List as many as you like: one account per line, each as
#   "Bank | Account number | Holder name"   (the "| Holder name" is optional).
# Separate accounts with a newline OR a ";". Single-line example:
#   BUSINESS_BANK_ACCOUNTS="ไทยพาณิชย์ | 123-4-56789-0 | อิ้ง; พร้อมเพย์ | 081-234-5678"
BUSINESS_BANK_ACCOUNTS=

# EasySlip — https://developer.easyslip.com (sign up, business KYC required,
# then Applications → Create New Application → copy the API Key).
EASYSLIP_API_KEY=

# ── Scheduled installment reminders (Phase 4) ──
# Any random string. Set the same value as a Vercel env var — Vercel Cron
# automatically sends it as "Authorization: Bearer $CRON_SECRET".
CRON_SECRET=
